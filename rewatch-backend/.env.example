# Backend environment variables
# Copy to .env and fill in values

# MongoDB connection string
# Example: mongodb+srv://user:pass@cluster.mongodb.net/rewatch
MONGODB_URI=
# Alternative: MONGO_URI=

# Server port (default: 5000)
PORT=5000

# JWT secret for auth tokens (REQUIRED in production)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional: Restrict CORS to your frontend URL in production
# FRONTEND_URL=https://your-app.vercel.app
