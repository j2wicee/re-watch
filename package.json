{
  "name": "re-watch",
  "version": "1.0.0",
  "private": true,
  "description": "Re:Watch - Anime tracking app",
  "scripts": {
    "start:frontend": "cd rewatch-frontend && npm start",
    "start:backend": "cd rewatch-backend && node index.js",
    "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:frontend": "cd rewatch-frontend && npm run build",
    "install:all": "npm install && cd rewatch-frontend && npm install && cd ../rewatch-backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
